# Stremio Account Manager - Environment Configuration
# Copy this file to .env and fill in your values
#
# SECURITY WARNING: Never commit .env to version control!

# ========================
# REQUIRED VARIABLES
# ========================

# JWT Secret - MUST be 64 character hex string (256 bits)
# Used to sign authentication tokens. Generate with:
#   openssl rand -hex 32
#
# KEEP THIS SECRET! Anyone with this key can forge valid JWTs.
JWT_SECRET=

# Encryption Key - 64 character hex string (256 bits for AES-256-GCM)
# Used to encrypt sensitive data (auth keys, 2FA secrets) in the database.
# Generate with:
#   openssl rand -hex 32
#
# IMPORTANT: If you lose this key, all encrypted data becomes unrecoverable!
# You must use the SAME key for all containers (don't generate different keys per container).
ENCRYPTION_KEY=

# ========================
# OPTIONAL VARIABLES
# ========================

# Frontend URL - the URL where the frontend is accessible
# Used for CORS headers and OAuth redirects
#
# For local development:
FRONTEND_URL=http://localhost:8080
#
# For production, use your actual domain:
# FRONTEND_URL=https://stremio.your-domain.com

# ========================
# GENERATION INSTRUCTIONS
# ========================

# On Linux/Mac:
#   openssl rand -hex 32
#
# On Windows (PowerShell):
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# On Windows (Git Bash or WSL):
#   openssl rand -hex 32

# ========================
# EXAMPLE COMPLETED CONFIG
# ========================

# JWT_SECRET=a1b2c3d4e5f6... (64 hex characters)
# ENCRYPTION_KEY=f6e5d4c3b2a1... (64 hex characters)
# FRONTEND_URL=http://localhost:8080